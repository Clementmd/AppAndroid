<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E1BEE7"
            android:gravity="center"
            android:padding="40dp"
            android:text="Ecole des loustics"
            android:textColor="#2C3E50"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProgression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Question 1 / 5"
            android:textColor="#BA68C8"
            android:textSize="18sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Quelle est la capitale de :"
            android:textColor="#2C3E50"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/tvPays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="France"
            android:textColor="#2C3E50"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etReponse"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="50dp"
            android:layout_marginTop="30dp"
            android:background="@android:drawable/edit_text"
            android:hint="Ta réponse ici..."
            android:inputType="textCapSentences"
            android:padding="15dp" />

        <Button
            android:id="@+id/btnValider"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="70dp"
            android:layout_marginTop="40dp"
            android:backgroundTint="#BA68C8"
            android:text="Valider la réponse"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            app:cornerRadius="8dp" />

        <Button
            android:id="@+id/btnQuitter"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="90dp"
            android:layout_marginTop="15dp"
            android:backgroundTint="#BDBDBD"
            android:text="Abandonner"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>