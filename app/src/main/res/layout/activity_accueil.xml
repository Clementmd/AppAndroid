<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E1BEE7"
        android:gravity="center"
        android:padding="40dp"
        android:text="Ecole des loustics"
        android:textColor="#2C3E50"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:text="Salut nom user"
        android:textColor="#2C3E50"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="Dans quoi veux tu t’exercer ?"
        android:textColor="#2C3E50"
        android:textSize="18sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnMaths"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="60dp"
        android:layout_marginTop="50dp"
        android:backgroundTint="#BA68C8"
        android:text="Exercices de Maths"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:cornerRadius="8dp" />

    <Button
        android:id="@+id/btnCulture"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="60dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="#BA68C8"
        android:text="Exercices de Géographie"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:cornerRadius="8dp" />

    <Button
        android:id="@+id/btnDeco"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="60dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="#BA68C8"
        android:text="Se deconnecter"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:cornerRadius="8dp" />

</LinearLayout>