<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E1BEE7"
        android:gravity="center"
        android:padding="40dp"
        android:text="Ecole des loustiques"
        android:textColor="#2C3E50"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:gravity="center"
        android:text="Résultats"
        android:textColor="#2C3E50"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFelicitations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:text="Félicitations"
        android:textColor="#2C3E50"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMessageSuccess"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:paddingHorizontal="30dp"
        android:text="Tu as toutes les bonnes réponses"
        android:textColor="#2C3E50"
        android:textSize="20sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChoisirAutre"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="60dp"
        android:layout_marginTop="60dp"
        android:backgroundTint="#BA68C8"
        android:text="Chosir une autre activité"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:cornerRadius="8dp" />

</LinearLayout>