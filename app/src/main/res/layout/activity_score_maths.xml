<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="30dp">

    <TextView
        android:id="@+id/tvScoreTitre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ton score : 5 / 5"
        android:textColor="#2C3E50"
        android:textSize="35sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvScoreMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="Message d'encouragement"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnRejouerMaths"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="50dp"
        android:backgroundTint="#BA68C8"
        android:text="Changer de niveau"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/btnRetourMenu"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="15dp"
        android:text="Retour au menu principal"
        android:textAllCaps="false"
        android:textColor="#BA68C8"
        app:strokeColor="#BA68C8" />

</LinearLayout>